<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="MciClock.Views.ClockDisplayWindow"
        Title="MCI Clock — Exibição"
        Background="#0a1e2b"
        SystemDecorations="None"
        WindowState="Maximized"
        Topmost="True"
		Icon="/Assets/favicon.ico"
        CanResize="False">

    <Panel x:Name="RootPanel">
        <!-- Background overlay for alert effect -->
        <Border x:Name="AlertBackground"
                Background="#e74c3c"
                Opacity="0"
                IsHitTestVisible="False"/>

        <!-- Main content -->
        <Grid RowDefinitions="*,Auto" x:Name="ContentGrid">

            <!-- Clock / Stopwatch display -->
            <Viewbox Grid.Row="0" Stretch="Uniform"
                     Margin="40">
                <StackPanel HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Spacing="0">

                    <!-- Clock mode -->
                    <TextBlock x:Name="ClockTimeText"
                               Text="00:00:00"
                               FontSize="280"
                               FontWeight="Bold"
                               Foreground="White"
                               HorizontalAlignment="Center"
                               FontFamily="Inter, Segoe UI, sans-serif"
                               LetterSpacing="8"/>

                    <!-- Date (clock mode only) -->
                    <TextBlock x:Name="ClockDateText"
                               Text=""
                               FontSize="48"
                               Foreground="#7ba7bc"
                               HorizontalAlignment="Center"
                               FontFamily="Inter, Segoe UI, sans-serif"
                               Margin="0,-10,0,0"/>

                    <!-- Label -->
                    <TextBlock x:Name="ModeLabel"
                               Text="RELÓGIO"
                               FontSize="32"
                               Foreground="#4a7080"
                               HorizontalAlignment="Center"
                               FontFamily="Inter, Segoe UI, sans-serif"
                               Margin="0,20,0,0"
                               LetterSpacing="6"/>
                </StackPanel>
            </Viewbox>

            <!-- Bottom bar with branding -->
            <Border Grid.Row="1"
                    Background="#0f2b3c"
                    Padding="24,8">
                <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Grid.Column="0"
                               Text="MCI Clock"
                               FontSize="14"
                               Foreground="#4a7080"
                               VerticalAlignment="Center"
                               FontWeight="SemiBold"/>
                    <TextBlock Grid.Column="1"
                               Text="Pressione ESC para fechar"
                               FontSize="12"
                               Foreground="#4a7080"
                               VerticalAlignment="Center"
                               Opacity="0.6"/>
                </Grid>
            </Border>

        </Grid>
    </Panel>
</Window>
